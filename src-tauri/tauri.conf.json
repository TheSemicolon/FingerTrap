{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FingerTrap",
  "version": "0.1.0",
  "identifier": "dev.fingertrap.app",
  "build": {
    "frontendDist": "../src-ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm --dir ../src-ui dev",
    "beforeBuildCommand": "pnpm --dir ../src-ui build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FingerTrap",
        "width": 1024,
        "height": 720,
        "minWidth": 600,
        "minHeight": 400
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "externalBin": ["binaries/fingertrap-sidecar"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
